<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-03-26T12:00:00.000Z" agent="Claude" version="21.0.0" type="device">
  <diagram id="pack-detection-pipeline" name="Pack Detection Pipeline">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Pack-Based PII Detection Pipeline" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- Input -->
        <mxCell id="input" value="Request Body" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- JSON Parse -->
        <mxCell id="json_check" value="Valid JSON?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="230" y="70" width="120" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="input" target="json_check" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Walk JSON -->
        <mxCell id="walk" value="Walk string&#xa;leaves recursively" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="400" y="55" width="140" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="json_check" target="walk" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Plain text -->
        <mxCell id="plain" value="Treat as&#xa;plain text" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="400" y="110" width="140" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="No" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="json_check" target="plain" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Pack Loader -->
        <mxCell id="pack_loader" value="Pack Loader&#xa;(enabledPacks filter)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- Pack boxes -->
        <mxCell id="pack_global" value="GLOBAL Pack&#xa;Email, API Key,&#xa;Credit Card (Luhn)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="240" y="190" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="pack_de" value="DE Pack&#xa;Steuer-ID (ISO 7064),&#xa;SVNR, KFZ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="410" y="190" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="pack_secrets" value="SECRETS Pack&#xa;SSH, JWT, Bearer,&#xa;DB Conn, AWS, GH" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="580" y="190" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="pack_us" value="US Pack&#xa;(disabled by default)&#xa;Phone, SSN, ZIP, IP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="190" width="150" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="pack_loader" target="pack_global" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="pack_loader" target="pack_de" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="pack_loader" target="pack_secrets" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Regex Pass -->
        <mxCell id="regex" value="Regex Pass&#xa;(per-pattern confidence)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="300" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="walk" target="regex" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="plain" target="regex" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Validate -->
        <mxCell id="validate" value="Checksum&#xa;Validator?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="380" y="390" width="140" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e9" value="Match" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="regex" target="validate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Skip -->
        <mxCell id="skip" value="Skip&#xa;(false positive)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="580" y="395" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e10" value="Fails" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="validate" target="skip" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Decay -->
        <mxCell id="decay" value="Apply Positional Decay&#xa;effective = base × (1 - (pos-1) × decay)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="260" y="500" width="280" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e11" value="Passes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="validate" target="decay" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Confidence check -->
        <mxCell id="conf_check" value="confidence&#xa;&gt;= aiThreshold?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="340" y="570" width="130" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="decay" target="conf_check" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Token generation -->
        <mxCell id="token" value="Generate Token&#xa;[PII_TYPE_16hex]&#xa;md5(original)[:16]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="590" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e13" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="conf_check" target="token" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Cache path -->
        <mxCell id="cache" value="Cache Lookup&#xa;(per-value)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="530" y="590" width="130" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e14" value="No" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="conf_check" target="cache" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Async Ollama -->
        <mxCell id="ollama" value="Async Ollama&#xa;(cache miss → dispatch)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="700" y="590" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e15" value="Miss" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="cache" target="ollama" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Output -->
        <mxCell id="output" value="Anonymized Text +&#xa;Session Token Map" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="710" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e16" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="token" target="output" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e17" value="Hit" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="cache" target="output" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e18" value="Fallback token" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="ollama" target="output" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
